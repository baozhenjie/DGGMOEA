def truncate_archive(archive, target_size):
 
    while len(archive) > target_size:
      
        objectives_matrix = np.array([ind.objectives for ind in archive])
        dist_matrix = distance_matrix(objectives_matrix, objectives_matrix)
        np.fill_diagonal(dist_matrix, np.inf)  
        

        min_dists = np.min(dist_matrix, axis=1)
    
        min_idx = np.argmin(min_dists)
        
      
        archive.pop(min_idx)
    
    return archive
class GANimproved:
    def __init__(self, latent_dim, decision_dim):
        self.latent_dim = latent_dim
        self.decision_dim = decision_dim
        
  
        self.discriminator = self.build_discriminator()
        self.discriminator.compile(loss='mse',
                                   optimizer=Adam(0.0002, 0.5),
                                   metrics=['accuracy'])
        
    
        self.generator = self.build_generator()
        

        self.discriminator.trainable = False
        z = Input(shape=(self.latent_dim,))
        generated_solution = self.generator(z)
        validity = self.discriminator(generated_solution)
        self.combined = Model(z, validity)
        self.combined.compile(loss='mse', optimizer=Adam(0.0002, 0.5))
        self.d_loss_history = []  
        self.g_loss_history = [] 
    def build_generator(self):
        model = Sequential()
        model.add(Dense(256, input_dim=self.latent_dim))
        model.add(LeakyReLU(alpha=0.2))
        model.add(BatchNormalization(momentum=0.8))
        model.add(Dense(512))
        model.add(LeakyReLU(alpha=0.2))
        model.add(BatchNormalization(momentum=0.8))
        model.add(Dense(1024))
        model.add(LeakyReLU(alpha=0.2))
        model.add(BatchNormalization(momentum=0.8))
        model.add(Dense(self.decision_dim, activation='linear'))
        return model
    
    def build_discriminator(self):
        model = Sequential()
        model.add(Dense(512, input_dim=self.decision_dim))
        model.add(LeakyReLU(alpha=0.2))
        model.add(Dropout(0.3))
        model.add(Dense(256))
        model.add(LeakyReLU(alpha=0.2))
        model.add(Dropout(0.3))
        model.add(Dense(128))
        model.add(LeakyReLU(alpha=0.2))
        model.add(Dense(1, activation='linear'))
        return model
    
    def train(self, archive_samples, rejected_samples, epochs=100, batch_size=32):

        valid = np.ones((batch_size, 1))*(1.)
        gen = np.ones((batch_size, 1))*(0.)
        fake = np.ones((batch_size, 1))*(-1.)
        epoch_d_losses = []  
        epoch_g_losses = []  
        for epoch in range(epochs):
         
            idx = np.random.randint(0, archive_samples.shape[0], batch_size)
            real_data = archive_samples[idx]
            d_loss_real = self.discriminator.train_on_batch(real_data, valid)
            
    
            idx = np.random.randint(0, rejected_samples.shape[0], batch_size)
            rejected_data = rejected_samples[idx]
            d_loss_rejected = self.discriminator.train_on_batch(rejected_data, fake)
           
            noise = np.random.normal(0, 1, (batch_size, self.latent_dim))
            gen_data = self.generator.predict(noise)
            d_loss_fake = self.discriminator.train_on_batch(gen_data, gen)
            
   
            d_loss =  d_loss_real + d_loss_rejected +  d_loss_fake
            

            mean = np.mean(archive_samples, axis=0)
            cov = np.cov(archive_samples, rowvar=False)
            
       
            cov += np.eye(cov.shape[0]) * 1e-6
            
  
            mean = np.mean(archive_samples, axis=0)
            cov = np.cov(archive_samples, rowvar=False)
            
        
            cov += np.eye(cov.shape[0]) * 1e-6
            
         
            noise = np.random.multivariate_normal(mean, cov, batch_size)
            g_loss = self.combined.train_on_batch(noise, valid)

    def generate_samples(self, archive_samples,n_samples):
    
    
        mean = np.mean(archive_samples, axis=0)
        cov = np.cov(archive_samples, rowvar=False)
   
        cov += np.eye(cov.shape[0]) * 1e-6
        

        noise = np.random.multivariate_normal(mean, cov, n_samples)
        return self.generator.predict(noise)


class CassandraManager:
    def __init__(self, contact_points=[''], port=9042, 
                 keyspace="compression_test", table="compressed_data"):
   
        auth_provider = PlainTextAuthProvider(username='cassandra', password='cassandra')
        self.cluster = Cluster(
            contact_points=contact_points,
            port=port,
            auth_provider=auth_provider,
            connect_timeout=30,
            idle_heartbeat_interval=30  
        )
        self.session = self.cluster.connect()
        self.keyspace = keyspace
        self.table = table
        
     
        self._setup_database()
    
    def _setup_database(self):
    
        #self.delete_keyspace()
        self.session.execute(f"""
            CREATE KEYSPACE IF NOT EXISTS {self.keyspace}
            WITH replication = {{'class': 'SimpleStrategy', 'replication_factor': 1}}
        """)
        
        self.session.execute(f"USE {self.keyspace}")
        
    
        self.session.execute(f"""
            CREATE TABLE IF NOT EXISTS {self.table} (
                id UUID PRIMARY KEY,
                compressed_data BLOB
            )
        """)
    
    def upload_data(self, algorithm, compressed_data):
    
        query = self.session.prepare(f"""
            INSERT INTO {self.table} (id, compressed_data)
            VALUES (?, ?)
        """)


     
        key = ore.generate_key()
 
        cipher = ore.Cipher(key)
     
        plaintext = random.randint(0, 2000000)
  
        ciphertext = cipher.encrypt(plaintext)
        data_id = ciphertext
      
        
       
        start_time = time.time()
        self.session.execute(query, (data_id, compressed_data))
        upload_time = (time.time() - start_time) * 1000 
        
        return data_id, upload_time
    
    def download_data(self, data_id):
    
        query = self.session.prepare(f"""
            SELECT compressed_data FROM {self.table} WHERE id = ?
        """)
        
 
        start_time = time.time()
        result = self.session.execute(query, [data_id])
        download_time = (time.time() - start_time) * 1000 
        
        if result:
            return result[0].compressed_data, download_time
        return None, download_time
    
    def delete_table(self):
      
        try:
            #print(f"准备删除表: {self.table}...")
            self.session.execute(f"DROP TABLE IF EXISTS {self.table}")
            #print(f"表 {self.table} 删除成功")
        except Exception as e:
            print(f"删除表时出错: {e}")
    
    def delete_keyspace(self):
       
        try:
            #print(f"准备删除键空间: {self.keyspace}...")
            self.session.execute(f"DROP KEYSPACE IF EXISTS {self.keyspace}")
            #print(f"键空间 {self.keyspace} 删除成功")
        except Exception as e:
            print(f"删除键空间时出错: {e}")
    def close(self):
       
        self.delete_table()
        self.session.shutdown()
        self.cluster.shutdown()

def compress_data(raw_data, algo_name):

    start_compress = time.time()
    
    if algo_name == "lzma":
        compressed = lzma.compress(raw_data, preset=9)
    elif algo_name == "zlib":
        compressed = zlib.compress(raw_data, level=9)
    elif algo_name == "lz4":
        compressed = lz4.frame.compress(raw_data, compression_level=9)
    elif algo_name == "snappy":
        compressed = snappy.compress(raw_data)
    elif algo_name == "bz2":
        compressed = bz2.compress(raw_data, compresslevel=9)
    
    compress_time = (time.time() - start_compress) * 1000
    
    return compressed, compress_time

def decompress_data(compressed_data, algo_name):
   
    start_decompress = time.time()
    
    if algo_name == "lzma":
        decompressed = lzma.decompress(compressed_data)
    elif algo_name == "zlib":
        decompressed = zlib.decompress(compressed_data)
    elif algo_name == "lz4":
        decompressed = lz4.frame.decompress(compressed_data)
    elif algo_name == "snappy":
        decompressed = snappy.decompress(compressed_data)
    elif algo_name == "bz2":
        decompressed = bz2.decompress(compressed_data)
    
    decompress_time = (time.time() - start_decompress) * 1000
    
    return decompressed, decompress_time

def encrypt_data(compressed_data, key, iv):
   
    cipher = AES.new(key, AES.MODE_CBC, iv)
    padded_data = pad(compressed_data, AES.block_size)
    
    start_encrypt = time.time()
    ciphertext = cipher.encrypt(padded_data)
    encrypt_time = (time.time() - start_encrypt) * 1000
    
    return ciphertext, encrypt_time

def decrypt_data(encrypted_data, key, iv):

    cipher = AES.new(key, AES.MODE_CBC, iv)
    
    start_decrypt = time.time()
    decrypted_padded = cipher.decrypt(encrypted_data)
    decrypted_data = unpad(decrypted_padded, AES.block_size)
    decrypt_time = (time.time() - start_decrypt) * 1000
    
    return decrypted_data, decrypt_time



class Individual:
  
    def __init__(self, algo_name, chunk_size):
        self.algo_name = algo_name
        self.chunk_size = chunk_size
        self.objectives = [None, None] 
        self.dominated = [] 
        self.dom_count = 0 
    def find_longest_row_pandas(self,csv_file):
        try:
           
            df = pd.read_csv(csv_file)
            if df.empty:
                return [] 
            
            last_row = df.tail(1).values.tolist()[0]
            print(last_row)
     
            matrix = [last_row.copy() for _ in range(self.chunk_size)]
            print(len(last_row))
           
            return len(last_row),matrix
        except Exception as e:
            print(f"错误：{e}")
            return []
        
    def evaluate(self, csv_path):
  
        cassandra = CassandraManager()
        key = get_random_bytes(16)
        iv = get_random_bytes(16)
        
        total_compressed_size = 0
        chunk_total_time = 0
        fw=2000.
        fr=2000.


  
        chunk_df=pd.read_csv(csv_path, nrows=self.chunk_size)
        raw_data = chunk_df.to_csv(index=False).encode('utf-8')

 
        compressed_data, compress_time = compress_data(raw_data, self.algo_name)

        
        total_compressed_size= (len(compressed_data)/len(raw_data))*(200000.***)
 
    
        encrypted_data, encrypt_time = encrypt_data(compressed_data, key, iv)
            
  
        data_id, upload_time = cassandra.upload_data(self.algo_name, encrypted_data)
            
    
        downloaded_data, download_time = cassandra.download_data(data_id)
            
      
        decrypted_data, decrypt_time = decrypt_data(downloaded_data, key, iv)
            
     
        decompressed_data, decompress_time = decompress_data(decrypted_data, self.algo_name)
       
        download_time =download_time*10 
        upload_time = upload_time*10
    
        chunk_total_time = (fw*compress_time + fw*encrypt_time + fw*upload_time + 
                           (fw+fr)*download_time + (fw+fr)*decrypt_time + (fw+fr)*decompress_time)
        #print(chunk_total_time/ (1000*3600.))
        cassandra.close()
        
       
        self.objectives = [total_compressed_size/ (1024 * 1024), chunk_total_time/ (1000*3600.)]
        return self.objectives


def dominates(ind1, ind2):

    better_or_equal = all(f1 <= f2 for f1, f2 in zip(ind1.objectives, ind2.objectives))
    strictly_better = any(f1 < f2 for f1, f2 in zip(ind1.objectives, ind2.objectives))
    return better_or_equal and strictly_better

